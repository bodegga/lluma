# Co-located issuer+broker origin (VPS-B). Copy to /etc/lluma/broker.env and fill.
# Bind the origin to loopback — only the gateway reaches it.
LLUMA_DB_PATH=/var/lib/lluma/broker.redb
LLUMA_ADMIN_SECRET=change-me-long-random
# Issuer RSA-BSSA key pair (DER) — produced by the issuer key-generation path.
LLUMA_ISSUER_SK_DER_FILE=/etc/lluma/keys/issuer_sk.der
LLUMA_ISSUER_PK_DER_FILE=/etc/lluma/keys/issuer_pk.der
# 32-byte Ed25519 registry secret key + 32-byte global PoW epoch salt (see gen-material.sh).
LLUMA_REGISTRY_SK_FILE=/etc/lluma/keys/registry.sk
LLUMA_EPOCH_SALT_FILE=/etc/lluma/keys/epoch_salt.bin
LLUMA_EPOCH=1
LLUMA_POW_DIFFICULTY=20
LLUMA_CORE_BIND=127.0.0.1:8080
LLUMA_INGRESS_BIND=127.0.0.1:8081
# LLUMA_ALLOW_ZERO_SALT is intentionally UNSET (prod). Setting it to 1 is dev-only.

# --- relay.env (VPS-A) ---
# LLUMA_RELAY_BIND=0.0.0.0:8780
# LLUMA_RELAY_GATEWAY=https://gateway.vps-b.example
# LLUMA_RELAY_MAX_BODY=65536
# LLUMA_RELAY_RL_CAPACITY=... ; LLUMA_RELAY_RL_REFILL=...

# --- gateway.env (VPS-B) ---
# LLUMA_GATEWAY_BIND=0.0.0.0:8782
# LLUMA_GATEWAY_ORIGIN=http://127.0.0.1:8080   # the co-located origin (loopback)
# LLUMA_GATEWAY_PREFIXES=/v1/key-config,/v1/issue,/v1/register,/v1/exec,/v1/snapshot
# LLUMA_GATEWAY_KEY_ID=1
